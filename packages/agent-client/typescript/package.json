{
  "name": "@microsandbox/agent-client",
  "version": "0.5.8",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./transports/websocket": {
      "types": "./dist/transports/websocket.d.ts",
      "import": "./dist/transports/websocket.js"
    },
    "./stream": {
      "types": "./dist/stream.d.ts",
      "import": "./dist/stream.js"
    },
    "./message": {
      "types": "./dist/message.d.ts",
      "import": "./dist/message.js"
    },
    "./frame": {
      "types": "./dist/frame.d.ts",
      "import": "./dist/frame.js"
    },
    "./packet": {
      "types": "./dist/packet.d.ts",
      "import": "./dist/packet.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "import": "./dist/transport.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run tests",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.6",
    "vitest": "^4.1"
  },
  "dependencies": {
    "cbor-x": "^1.6.0"
  }
}
